@model OnlineExamSystem.ViewModels.ExamViewModel

@{
    ViewData["Title"] = $"Take Exam - {Model.ExamTitle}";
}

<h2 class="mt-4 mb-3">@Model.ExamTitle</h2>

<form asp-action="Take" method="post">

    <input type="hidden" asp-for="ExamId" />
    <input type="hidden" asp-for="ExamTitle" />

    @for (var i = 0; i < Model.Questions.Count; i++)
    {
        var q = Model.Questions[i];
        <div class="mb-4 p-3 border rounded">
            <p><strong>Question @(i + 1):</strong> @q.QuestionText</p>
            @foreach (var option in q.Options)
            {
                string optionId = $"q{q.QuestionId}_o{option.OptionId}";
                <div class="form-check">
                    <input class="form-check-input" type="radio"
                           id="@optionId"
                           name="Questions[@i].SelectedOptionId"
                           value="@option.OptionId" />
                    <label class="form-check-label" for="@optionId">@option.OptionText</label>
                </div>
            }
        </div>
    }
    <button type="submit" class="btn btn-success">Submit Exam</button>
</form>
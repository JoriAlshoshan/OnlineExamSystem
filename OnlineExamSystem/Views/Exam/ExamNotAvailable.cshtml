@model OnlineExamSystem.Models.Exam

@{
    ViewData["Title"] = "Exam Not Available";
}

<div class="alert alert-warning mt-4">
    <h4 class="alert-heading">Exam Not Available</h4>
    <p>
        The exam <strong>@Model.Title</strong> is not currently available.  Please check
        the scheduled start and end times:
    </p>
    <ul>
        <li><strong>Start:</strong> @Model.StartTime.ToString("f")</li>
        <li><strong>End:</strong> @Model.EndTime.ToString("f")</li>
    </ul>
    <p>Return to the <a asp-controller="Exam" asp-action="Index">exam list</a> to see other available exams.</p>
</div>
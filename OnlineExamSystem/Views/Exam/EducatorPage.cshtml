@model IEnumerable<OnlineExamSystem.Models.Exam>

@{
    ViewData["Title"] = "Educator Page";
    Layout = "_Layout";
}

<h2>Educator Page</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Exam</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Subject</th>
            <th>Difficulty</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Duration (min)</th>
            <th>Created By</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var exam in Model)
            {
                <tr>
                    <td>@exam.Title</td>
                    <td>@exam.Subject?.Name</td>
                    <td>@exam.Difficulty</td>
                    <td>@exam.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@exam.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@exam.DurationMinutes</td>
                    <td>@exam.CreatedByUser?.FullName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@exam.ExamId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@exam.ExamId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center">No exams found.</td>
            </tr>
        }
    </tbody>
</table>

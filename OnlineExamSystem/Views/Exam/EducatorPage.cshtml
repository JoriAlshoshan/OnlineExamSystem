@model IEnumerable<OnlineExamSystem.Models.Exam>

@{
    ViewData["Title"] = "Educator Page";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Exams</h2>
    <a class="btn btn-success" asp-controller="Exam" asp-action="Create">Create New Exam</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Subject</th>
            <th>Difficulty</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Duration (min)</th>
            <th>Created By</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var exam in Model)
        {
            <tr>
                <td>@exam.Title</td>
                <td>@exam.Subject?.Name</td>
                <td>@exam.Difficulty</td>
                <td>@exam.StartTime.ToString("g")</td>
                <td>@exam.EndTime.ToString("g")</td>
                <td>@exam.DurationMinutes</td>
                <td>@exam.CreatedByUser?.UserName</td>
                <td>
                    <a class="btn btn-primary btn-sm" asp-controller="Exam" asp-action="Edit" asp-route-id="@exam.ExamId">Edit</a>
                    <a class="btn btn-danger btn-sm" asp-controller="Exam" asp-action="Delete" asp-route-id="@exam.ExamId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

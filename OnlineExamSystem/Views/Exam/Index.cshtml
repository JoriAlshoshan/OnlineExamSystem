@model OnlineExamSystem.ViewModels.PagedResult<OnlineExamSystem.ViewModels.ExamViewModel>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";
}


<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="table-responsive">
    <table id="examGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(m => m.Data.FirstOrDefault().Title)</th>
                <th>@Html.DisplayNameFor(m => m.Data.FirstOrDefault().Description)</th>
                <th>@Html.DisplayNameFor(m => m.Data.FirstOrDefault().StartDate)</th>
                <th>@Html.DisplayNameFor(m => m.Data.FirstOrDefault().Time)</th>
             
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Data)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.Time hours</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Bootstrap 5 Pagination -->
@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage - 1)">Previous</a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

<!-- Print PDF Button -->
<a id="printPDF" class="btn btn-primary mt-2">Print</a>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#examGrid').DataTable({
                "paging": false,
                "filter": true
            });

            $("#printPDF").click(function () {
                var element = document.getElementById('examGrid');
                var mode = "avoid-all";
                var pagebreak = (mode === 'specify') ?
                    { mode: '', before: '.before', after: '.after', avoid: '.avoid' } :
                    { mode: mode };

                // Generate the PDF using html2pdf.js
                html2pdf().from(element).set({
                    margin: [30, 10, 5, 10],
                    pagebreak: { avoid: 'tr' },
                    jsPDF: { orientation: 'landscape', unit: 'pt', format: 'letter', compressPDF: true }
                }).save();
            });
        });
    </script>
}

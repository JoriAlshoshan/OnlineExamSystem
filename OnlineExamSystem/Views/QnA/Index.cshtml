@model OnlineExamSystem.ViewModels.PagedResult<OnlineExamSystem.ViewModels.QnAViewModel>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";

}



<h1>Exam Papers</h1>


<div class="mb-3">
    <a asp-action="Create" asp-controller="QnAs" class="btn btn-primary">Create New</a>
</div>

<div class="table-responsive">
    <table id="qnaGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%">
        <thead class="thead-dark">
            <tr>
                <th>Question</th>
                <th>Answer</th>
                <th>Option 1</th>
                <th>Option 2</th>
                <th>Option 3</th>
                <th>Option 4</th>
                <th>Total Count</th>
                <th>Selected Answer</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Data)
        {
            <tr>
                <td>@item.Question</td>
                <td>@item.Answer</td>
                <td>@item.option1</td>
                <td>@item.option2</td>
                <td>@item.option3</td>
                <td>@item.option4</td>
                <td>@item.TotalCount</td>
                <td>@item.SelectedAnswar</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <cs-pager cs-paging-pagesize="@Model.PageSize"
              cs-paging-pagenumber="@Model.PageNumber"
              cs-paging-totalitems="@Model.TotalItem"
              cs-pager-li-current-class="page-item active"
              cs-pager-li-other-class="page-item"
              cs-pager-li-non-active-class="page-item disabled"
              cs-pager-link-current-class="page-link"
              cs-pager-link-other-class="page-link">
    </cs-pager>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#qnaGrid').DataTable({
                "paging": false, 
                "filter": true
            });
        });
    </script>
}

@using OnlineExamSystem.ViewModels
@model VerifyEmailViewModel

@{
    ViewData["Title"] = "Verify Your Email";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="account-container">
    <div class="account-box shadow-sm">
        <h2 class="account-title text-center mb-4">Verify Your Email</h2>
        <p style="color:red;">@ViewBag.Error</p>

        <form asp-action="SendResetLink" method="post" novalidate>
            @Html.AntiForgeryToken()

            <label asp-for="Email" class="form-label">Email Address</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="Enter your email" />
            <span asp-validation-for="Email" class="text-danger"></span>

            <button type="submit" class="btn btn-primary w-100 btn-lg mt-4">Send Reset Link</button>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    @if (ViewBag.Error != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@ViewBag.Error',
                confirmButtonText: 'OK'
            });
        </script>
    }
}




@using Microsoft.AspNetCore.Identity
@inject SignInManager<OnlineExamSystem.Models.UsersApp> SignInManager
@inject UserManager<OnlineExamSystem.Models.UsersApp> UserManager
@{
    var title = ViewData["Title"] as string ?? "OnlineExam";
    OnlineExamSystem.Models.UsersApp user = null;
    if (SignInManager.IsSignedIn(User))
    {
        user = await UserManager.GetUserAsync(User);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - OnlineExam</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/onlineExamApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
            <div class="container d-flex justify-content-between align-items-center">

                <ul class="navbar-nav d-flex align-items-center">
                    @if (user != null)
                    {
                        <li class="nav-item me-2">
                            <a class="nav-link p-0" asp-controller="Profile" asp-action="Edit">
                                <img src="@(!string.IsNullOrEmpty(user.ProfileImagePath) ? user.ProfileImagePath : "/images/defualt_user.png")"
                                     alt="Profile"
                                     width="40"
                                     height="40"
                                     class="rounded-circle border border-success border-2" />
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <span class="navbar-text fw-bold fs-5 text-success">OnlineExam</span>
                    </li>
                </ul>

                <ul class="navbar-nav d-flex align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger fw-bold px-3">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>

            </div>
        </nav>
    </header>

    <div class="main-content">
        <div class="content-box container py-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="text-center py-4 bg-light text-muted">
        &copy; @DateTime.Now.Year OnlineExam. All rights reserved.
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


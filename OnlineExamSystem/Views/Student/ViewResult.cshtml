@model IEnumerable<OnlineExamSystem.ViewModels.ExamResultViewModel>

@{
    ViewData["Title"] = "ViewResult";
}


<h1>Exam Results</h1>

<div id="parentDiv">
    <br />
    <div>
        <table id="resultGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%">
            <thead>
                <tr>
                    <th>Exam Name</th>
                    <th>Total Questions</th>
                    <th>Correct</th>
                    <th>Wrong</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ExamName</td>
                        <td>@item.TotalQuetion</td>
                        <td>@item.CorrectAnswer</td>
                        <td>@item.WrongAnswer</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Profile" class="btn btn-primary">Profile</a>
    <button id="printPDF" class="btn btn-success">Print PDF</button>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#resultGrid').DataTable({
                responsive: true
            });

            $("#printPDF").click(function () {
                var element = document.getElementById('parentDiv');
                html2pdf().from(element).set({
                    margin: [30, 10, 5, 10],
                    pagebreak: { avoid: 'tr' },
                    jsPDF: { orientation: 'landscape', unit: 'pt', format: 'letter', compressPDF: true }
                }).save();
            });
        });
    </script>
}


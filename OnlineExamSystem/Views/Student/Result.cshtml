@model IEnumerable<OnlineExamSystem.ViewModels.ExamResultViewModel>

@{
    ViewData["Title"] = "Result";
}


<h1>Student Exam Results</h1>

<div id="parentDiv">
    <br />
    <table id="resultGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
        <thead>
            <tr>
                <th>Exam Name</th>
                <th>Total Questions</th>
                <th>Correct</th>
                <th>Wrong</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ExamName</td>
                    <td>@item.TotalQuetion</td>
                    <td>@item.CorrectAnswer</td>
                    <td>@item.WrongAnswer</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Student List</a>
    <button id="printPDF" class="btn btn-primary">Print</button>
</div>

@section Scripts {
    <script>
        $("#printPDF").click(function () {
            var element = document.getElementById('parentDiv');

            html2pdf().from(element).set({
                margin: [30, 10, 5, 10], // top, left, bottom, right
                pagebreak: { avoid: 'tr' },
                jsPDF: { orientation: 'landscape', unit: 'pt', format: 'letter', compressPDF: true }
            }).save();
        });
    </script>
}


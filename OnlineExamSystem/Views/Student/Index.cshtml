@model OnlineExamSystem.ViewModels.PagedResult<OnlineExamSystem.ViewModels.StudentViewModel>

@{
    ViewData["Title"] = "Students List";
}

<h1>Students</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Items.First().Id)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().Name)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().UserName)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().Password)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().Contact)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().CVFileName)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().PictureFileName)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().GroupsId)</th>
            <th>@Html.DisplayNameFor(model => model.Items.First().TotalCount)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model.Items)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.UserName</td>
                <td>@student.Password</td>
                <td>@student.Contact</td>
                <td>@student.CVFileName</td>
                <td>@student.PictureFileName</td>
                <td>@student.GroupsId</td>
                <td>@student.TotalCount</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = student.Id }) |
                    @Html.ActionLink("Details", "Details", new { id = student.Id }) |
                    @Html.ActionLink("Delete", "Delete", new { id = student.Id })
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination">
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)">Previous</a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                </li>
            }

            <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

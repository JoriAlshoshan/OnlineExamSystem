@model OnlineExamSystem.Models.UsersApp

@{
    ViewData["Title"] = "Edit Profile";
}

<h2 class="mb-4">Edit Profile</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-body d-flex flex-column align-items-center">
                <img src="@(Model.ProfileImagePath ?? "/images/defualt_user.png")"
                     alt="profile"
                     width="120"
                     height="120"
                     class="rounded-circle border border-2 mb-3" />

                <form asp-action="UploadImage" method="post" enctype="multipart/form-data" class="w-100">
                    <div class="mb-3">
                        <label class="form-label">Choose Profile Image (.jpg/.png, max 2MB):</label>
                        <input type="file" name="profileImage" accept=".jpg,.jpeg,.png" class="form-control" required />
                    </div>
                    <div class="text-center">
                        <button type="submit" class="btn btn-sm btn-outline-primary">Upload Image</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="EditProfile" method="post">
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" disabled />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="NewPassword">New Password</label>
                        <input type="password" name="NewPassword" class="form-control" minlength="6" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="ConfirmPassword">Confirm Password</label>
                        <input type="password" name="ConfirmPassword" class="form-control" minlength="6" />
                    </div>

                    <div class="alert alert-secondary small">
                        Leave password fields empty if you don't want to change your password.
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-success me-2">Save Changes</button>
                        <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


